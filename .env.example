# Bearer token for the REST API (auto-generated on first boot if empty)
API_TOKEN=

# REST API host/port (defaults: 127.0.0.1 / 8080)
HOST=127.0.0.1
PORT=8080

# Optional: HTTP endpoint to POST inbound messages to.
# Leave empty to disable the webhook.
WEBHOOK_URL=

# Optional: bearer token sent as Authorization header to WEBHOOK_URL.
WEBHOOK_TOKEN=
